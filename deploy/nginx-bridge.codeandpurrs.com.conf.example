server {
    listen 80;
    listen [::]:80;
    server_name bridge.codeandpurrs.com;

    # Cloudflare should terminate public TLS; this vhost proxies to the local Node bridge.
    # If you enable origin TLS on the VPS, move this block to listen 443 with your certs.

    client_max_body_size 512k;

    location /api/usage/ {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    location = / {
        return 200 'Neko Usage Bridge is alive.\n';
        add_header Content-Type text/plain;
    }
}
