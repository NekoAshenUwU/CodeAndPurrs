{
  "name": "codeandpurrs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c magenta,cyan \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:server": "node --env-file-if-exists=.env server/proxy.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "^10.0.3",
    "playwright": "^1.56.1",
    "typescript": "latest",
    "vite": "latest"
  }
}
