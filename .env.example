# Neko Usage Bridge VPS settings
# Copy to .env on the VPS or set these in systemd Environment= lines.

HOST=127.0.0.1
PORT=8787

# Required in production. Keep this secret; it must match the Redmi bridge app.
USAGE_BRIDGE_TOKEN=replace-with-a-long-random-secret

# Comma-separated origins allowed to read bridge data from the browser.
# Add the final CodeAndPurrs frontend origin when it is chosen.
USAGE_BRIDGE_ALLOWED_ORIGINS=https://bridge.codeandpurrs.com,https://tang.nekopurrs.uk

# Optional: 0 disables automatic pruning. 60 keeps roughly two months per owner.
USAGE_BRIDGE_RETENTION_DAYS=60

# Frontend-only demo mode. Set to 1 locally to render Paw Trail without calling the bridge.
VITE_USAGE_BRIDGE_DEMO=0
