# 复制成 .env，填上你自己的 key，再重启后端（npm run dev）。
# .env 已被 .gitignore 忽略，不会提交，放心填。
# 一个都不填也行 —— 后端会进 mock 模式，回假消息，方便先调界面。

# DeepSeek：https://platform.deepseek.com/  默认模型 deepseek-chat
DEEPSEEK_API_KEY=

# Gemini：https://aistudio.google.com/apikey  默认模型 gemini-2.5-flash
GEMINI_API_KEY=

# ElevenLabs：AI 给你发语音的音色。https://elevenlabs.io/
# 不填就用 mock（一段哔声占位）；填了猫咪的语音就是你选的音色。
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# 默认 eleven_multilingual_v2（中文也行），一般不用改
ELEVENLABS_MODEL=eleven_multilingual_v2

# 后端代理端口（不改就用 8787，要改的话 vite.config.ts 里的 proxy 也要跟着改）
PORT=8787
